# ─────────────────────────────────────────────────────────────
# Athroics — 餐厅模块环境变量
# 复制本文件为 .env 并填入真实值。切勿把 .env 提交到 git。
# ─────────────────────────────────────────────────────────────

# --- 数据库 (Turso / libSQL) ---
# 本地开发可留空，会自动回退到 file:./local.db
# 部署到云端（Vercel 等 serverless 文件系统只读）时必须用 Turso：
#   turso db create athroics && turso db show athroics --url   → 填 TURSO_DATABASE_URL
#   turso db tokens create athroics                            → 填 TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- 只读演示（放个人网站给别人看，但不消耗你的 API/不改你的数据）---
# DEMO_MODE=1        服务端硬闸：拦截所有写请求 + 会花钱的读请求（middleware.ts）
# NEXT_PUBLIC_DEMO_MODE=1  前端软闸：隐藏花钱/写入入口 + 顶部只读横幅
# 两个都设成 1 才是完整只读演示；平时自用留空。
DEMO_MODE=
NEXT_PUBLIC_DEMO_MODE=
# 部署后的真实域名（用于 OG/社媒分享图的绝对地址）。留空则用 localhost。
NEXT_PUBLIC_SITE_URL=

# --- Google Places API (餐厅数据) ---
GOOGLE_PLACES_API_KEY=

# --- Anthropic API (从小红书文本提取餐厅名) ---
ANTHROPIC_API_KEY=

# --- 成本熔断 ---
# Google Places 月度花费硬上限（美元），超过即停止调用
GOOGLE_PLACES_MONTHLY_CAP_USD=180
# Anthropic 月度软上限（美元）
ANTHROPIC_MONTHLY_CAP_USD=20
# 地图圈选搜索（②B）月度预算硬熔断（美元），独立一条防烧钱
AREA_SEARCH_MONTHLY_CAP_USD=5

# --- Telegram bot（用手机聊天选餐）---
# 1) 找 @BotFather 建 bot，拿到 token 填这里
# 2) 自己随便生成一串密钥填 TELEGRAM_WEBHOOK_SECRET
# 3) 部署后注册 webhook（把 <TOKEN>/<SECRET>/<你的域名> 换掉）：
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<你的域名>/api/telegram&secret_token=<SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# 后续模块占位（本轮不用，先留着）
# ─────────────────────────────────────────────────────────────
# TMDB_API_KEY=
# TICKETMASTER_API_KEY=
